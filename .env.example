# When set to "true", all routes show the /coming-soon page (except static assets and /coming-soon).
# Omit this variable or set to anything else for the full site (e.g. local `npm run dev`).
# Set in Vercel: Project → Settings → Environment Variables → Production only.
# COMING_SOON=true

# Optional: visit https://yoursite.com?sba_preview=YOUR_SECRET once to set a bypass cookie
# and browse the real site on production while the banner is on for everyone else.
# COMING_SOON_BYPASS_SECRET=choose-a-long-random-string
